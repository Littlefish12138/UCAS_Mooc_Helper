{
  "$schema": "file:///f:/coding/临时工具、临时测试/UCAS_MOOC/page_locator.json",
  "name": "course_tree",
  "description": "整个课程树元素",
  "locator_method": {
    "type": ["ele"],
    "locator": ["#coursetree", ".onetoone"]
  },
  "sub_elements": [
    {
      "name": "chapter",
      "description": "一章的父元素",
      "locator_method": {
        "type": ["children", "eles"],
        "locator": [".cells"]
      },
      "virtual_dict": {
        "key": "chapters",
        "container": "$root"
      },
      "sub_elements": [
        {
          "name": "titie",
          "description": "一章的标题元素",
          "locator_method": {
            "type": ["child", "ele"],
            "locator": ["tag:h3"]
          },
          "sub_elements": [
            {
              "name": "chapter_title_span",
              "description": "一章的标题子元素",
              "locator_method": {
                "type": ["ele"],
                "locator": ["tag:span", ".titlewords"]
              },
              "targets": {
                "title": {
                  "type": "information",
                  "description": "一章的标题",
                  "container": "$parent",
                  "key": "title",
                  "value": {
                    "method": "raw_text"
                  }
                }
              }
            }
          ]
        },
        {
          "name": "section",
          "description": "一节视频的父元素",
          "locator_method": {
            "type": ["children", "eles"],
            "locator": [".ncells"]
          },
          "virtual_dict": {
            "key": "sections",
            "container": "$parent"
          },
          "presence": "optional",
          "sub_elements": [
            {
              "name": "titie",
              "description": "一节视频的标题和href所在元素",
              "locator_method": {
                "type": ["ele"],
                "locator": ["tag:a"]
              },
              "targets": {
                "section_titie": {
                  "type": "information",
                  "description": "一节视频的标题",
                  "container": "$parent",
                  "key": "titie",
                  "value": {
                    "method": "raw_text"
                  }
                },
                "click_callback_js": {
                  "type": "method",
                  "description": "点击回调，来自其href属性",
                  "container": "$parent",
                  "key": "click_callback_js",
                  "method": "run_js",
                  "args": "eval(this.href)"
                },
                "click_callback": {
                  "type": "method",
                  "description": "点击回调，使用时需要确保章节树展开",
                  "container": "$parent",
                  "key": "click_callback",
                  "method": "click"
                }
              }
            }
          ]
        }
      ]
    }
  ]
}
